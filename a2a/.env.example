# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for local runs.
# In production these are injected from Secret Manager by Cloud Run
# (see .github/workflows/deploy.yml). Never commit the real .env.
# ─────────────────────────────────────────────────────────────

# --- Vertex AI / GCP ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE
VERTEX_IMAGEN_LOCATION=us-central1
IMAGE_BUCKET=your-gcs-bucket-name

# --- Blogger + Google Indexing (OAuth) ---
# IMPORTANT: BLOGGER_REFRESH_TOKEN must be generated under the account that
# OWNS the blog, not the GCP project owner. It must carry BOTH scopes:
# .../auth/blogger and .../auth/indexing. Generate locally with
# get_refresh_token.py (not committed; gitignored).
BLOGGER_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
BLOGGER_CLIENT_SECRET=your-oauth-client-secret
BLOGGER_REFRESH_TOKEN=your-refresh-token
BLOGGER_BLOG_ID=0000000000000000000

# --- Facebook Page ---
FACEBOOK_PAGE_ID=000000000000000
FACEBOOK_PAGE_ACCESS_TOKEN=your-permanent-page-access-token
FACEBOOK_API_VERSION=v21.0

# ─────────────────────────────────────────────────────────────
# A2A topology — where each specialist service lives.
# ─────────────────────────────────────────────────────────────
# The ORCHESTRATOR reads these to find the remote agent cards.
# Locally they default to localhost ports; in production set them to the
# Cloud Run service URLs of each specialist.
RESEARCHER_AGENT_URL=http://localhost:8001
WRITER_AGENT_URL=http://localhost:8002
PUBLISHER_AGENT_URL=http://localhost:8003

# Each SPECIALIST advertises its own public URL inside its agent card.
# On Cloud Run set these to that service's own URL (so the card's `url`
# field is correct for clients). Locally they default to localhost:<PORT>.
RESEARCHER_PUBLIC_URL=http://localhost:8001
WRITER_PUBLIC_URL=http://localhost:8002
PUBLISHER_PUBLIC_URL=http://localhost:8003

# Optional MCP server path overrides (default: auto-resolved inside common/servers).
# FEED_SERVER_PATH=
# BLOGGER_SERVER_PATH=
# FACEBOOK_SERVER_PATH=
